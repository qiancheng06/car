<?xml version="1.0"?>
<robot name="racecar">
  <material name="body_blue"><color rgba="0.10 0.35 0.80 1.0"/></material>
  <material name="wheel_black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="sensor_red"><color rgba="0.85 0.10 0.10 1.0"/></material>
  <material name="sensor_green"><color rgba="0.10 0.70 0.20 1.0"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry><box size="0.45 0.16 0.12"/></geometry>
      <material name="body_blue"/>
    </visual>
    <collision><geometry><box size="0.45 0.16 0.12"/></geometry></collision>
  </link>
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/><child link="base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="sensor_red"/>
    </visual>
  </link>
  <joint name="base_footprint_to_laser" type="fixed">
    <parent link="base_footprint"/><child link="laser_link"/>
    <origin xyz="0.07 0 0" rpy="0 0 0"/>
  </joint>

  <link name="IMU_link">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.03 0.015"/></geometry>
      <material name="sensor_green"/>
    </visual>
  </link>
  <joint name="base_footprint_to_imu" type="fixed">
    <parent link="base_footprint"/><child link="IMU_link"/>
    <origin xyz="0.1653 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_wheel_link">
    <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.06" length="0.03"/></geometry><material name="wheel_black"/></visual>
  </link>
  <joint name="left_wheel_joint" type="fixed">
    <parent link="base_footprint"/><child link="left_wheel_link"/>
    <origin xyz="0.10 0.175 0.06" rpy="0 0 0"/>
  </joint>

  <link name="right_wheel_link">
    <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.06" length="0.03"/></geometry><material name="wheel_black"/></visual>
  </link>
  <joint name="right_wheel_joint" type="fixed">
    <parent link="base_footprint"/><child link="right_wheel_link"/>
    <origin xyz="0.10 -0.175 0.06" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_link">
    <visual><geometry><sphere radius="0.025"/></geometry><material name="wheel_black"/></visual>
  </link>
  <joint name="caster_front_joint" type="fixed">
    <parent link="base_footprint"/><child link="caster_front_link"/>
    <origin xyz="0.19 0 0.025" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_link">
    <visual><geometry><sphere radius="0.025"/></geometry><material name="wheel_black"/></visual>
  </link>
  <joint name="caster_back_joint" type="fixed">
    <parent link="base_footprint"/><child link="caster_back_link"/>
    <origin xyz="-0.19 0 0.025" rpy="0 0 0"/>
  </joint>
</robot>
